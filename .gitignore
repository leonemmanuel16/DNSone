# =============================================================================
# DNS One — .gitignore
# =============================================================================

# ---- Secretos y entorno ----
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# ---- Python / Backend ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Entornos virtuales
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Mypy / ruff / etc
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Alembic — mantener migraciones, ignorar SQLite local si aplicara
backend/*.db
backend/*.sqlite

# ---- Node / Frontend ----
node_modules/
.next/
out/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build artifacts
.cache/
.parcel-cache/

# ---- Editores / IDE / dev tooling local ----
.vscode/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Docker ----
*.pid
postgres-data/
docker-data/

# ---- PDF / artefactos generados ----
backend/app/pdf/output/
*.pdf.tmp

# ---- Logs ----
logs/
*.log
log/

# ---- Otros ----
.history/
tmp/
temp/
