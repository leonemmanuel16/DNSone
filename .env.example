# =============================================================================
# DNS One — variables de entorno (ejemplo)
# Copia este archivo a `.env` y completa los valores reales.
# Nunca subas `.env` al repo. Está en .gitignore.
# =============================================================================

# ---- Aplicación ----
APP_ENV=development            # development | staging | production
APP_NAME=DNS One
APP_TIMEZONE=America/Monterrey
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Base de datos (Postgres) ----
POSTGRES_USER=dnsone
POSTGRES_PASSWORD=dnsone_change_me
POSTGRES_DB=dns_one
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://dnsone:dnsone_change_me@db:5432/dns_one

# ---- Seguridad / JWT ----
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas

# ---- Admin inicial (solo se usa en seed) ----
ADMIN_EMAIL=admin@dns.com.mx
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=DNS One Administrator

# ---- Reglas comerciales ----
DEFAULT_CURRENCY=USD                  # USD | MXN
DEFAULT_EXCHANGE_RATE_USD_MXN=19.00   # MXN por 1 USD
DEFAULT_TAX_PCT=16.00
PRICE_DECIMAL_PLACES=2

# ---- Integración BIND (Bind ERP) ----
BIND_BASE_URL=
BIND_API_TOKEN=
BIND_TIMEOUT_SECONDS=30
BIND_MAX_RETRIES=3
BIND_USE_MOCK=true                    # true mientras no haya credenciales reales

# ---- Scheduler ----
SYNC_INTERVAL_MINUTES=30
SCHEDULER_ENABLED=true

# ---- PDF ----
PDF_TEMPLATE_NAME=dns_one_quote
PDF_OUTPUT_DIR=/app/pdf_output

# ---- Despliegue ----
GITHUB_REPO_URL=https://github.com/leonemmanuel16/dnsone
PUBLIC_BASE_URL=https://dnsone.example.com   # se reemplaza con el subdominio real de Azure
